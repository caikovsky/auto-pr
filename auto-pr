#######################################
# Jira Functions
#######################################

extract_jira_ticket() {
    local branch_name="$1"
    echo "$branch_name" | grep -oE '[A-Z]+-[0-9]+' | head -1
}

fetch_jira_ticket_json() {
    local ticket="$1"
    log_info "Fetching Jira ticket: $ticket"
    
    local response
    response=$(acli jira workitem view "$ticket" --json 2>&1)
    
    if [[ $? -ne 0 ]] || echo "$response" | grep -qi '"error"\|not found'; then
        log_error "Failed to fetch Jira ticket: $ticket"
        return 1
    fi
    
    echo "$response"
}

get_ticket_title() {
    echo "$1" | jq -r '.fields.summary // "No title"'
}

get_ticket_description() {
    echo "$1" | jq -r '
        def extract_text:
            if type == "object" then
                if .text then .text
                elif .content then (.content | map(extract_text) | join(" "))
                else ""
                end
            elif type == "array" then
                map(extract_text) | join(" ")
            else ""
            end;
        .fields.description | extract_text
    ' 2>/dev/null | tr '\n' ' ' | sed 's/  */ /g'
}

get_ticket_type() {
    echo "$1" | jq -r '.fields.issuetype.name // "Task"'
}

get_ticket_acceptance_criteria() {
    # Try to extract acceptance criteria from custom fields or description
    echo "$1" | jq -r '
        .fields.customfield_10014 // 
        .fields.customfield_10015 // 
        ""
    ' 2>/dev/null
}

get_ticket_url() {
    local ticket="$1"
    local site
    site=$(acli auth status 2>/dev/null | grep -oE '[a-zA-Z0-9.-]+\.atlassian\.net' | head -1)
    
    if [[ -n "$site" ]]; then
        echo "https://${site}/browse/${ticket}"
    else
        echo "https://YOURSITE.atlassian.net/browse/${ticket}"
    fi
}

#######################################
# Git Functions
#######################################

get_base_branch() {
    local base="$1"
    
    if git rev-parse --verify "$base" &>/dev/null; then
        echo "$base"
    elif git rev-parse --verify "origin/$base" &>/dev/null; then
        echo "origin/$base"
    elif git rev-parse --verify "origin/main" &>/dev/null; then
        echo "origin/main"
    elif git rev-parse --verify "origin/master" &>/dev/null; then
        echo "origin/master"
    else
        echo ""
    fi
}

get_commit_messages() {
    local base_branch="$1"
    
    if [[ -z "$base_branch" ]]; then
        git log --oneline -20 --pretty=format:"%s" 2>/dev/null
    else
        git log "${base_branch}..HEAD" --oneline --pretty=format:"%s" 2>/dev/null
    fi
}

get_changed_files() {
    local base_branch="$1"
    
    if [[ -z "$base_branch" ]]; then
        git diff --name-only HEAD~1 2>/dev/null || git ls-files 2>/dev/null
    else
        git diff --name-only "${base_branch}..HEAD" 2>/dev/null
    fi
}

get_diff_content() {
    local base_branch="$1"
    local max_lines="${2:-500}"
    
    local diff
    if [[ -z "$base_branch" ]]; then
        diff=$(git diff HEAD~1 2>/dev/null)
    else
        diff=$(git diff "${base_branch}..HEAD" 2>/dev/null)
    fi
    
    # Truncate if too long (to fit API limits)
    echo "$diff" | head -n "$max_lines"
}

get_diff_stat() {
    local base_branch="$1"
    
    if [[ -z "$base_branch" ]]; then
        git diff --stat HEAD~1 2>/dev/null
    else
        git diff --stat "${base_branch}..HEAD" 2>/dev/null
    fi
}

#######################################
# AI Analysis with Gemini
#######################################

call_gemini_api() {
    local prompt="$1"
    
    local request_body
    request_body=$(jq -n \
        --arg prompt "$prompt" \
        '{
            contents: [{
                parts: [{
                    text: $prompt
                }]
            }],
            generationConfig: {
                temperature: 0.3,
                maxOutputTokens: 2048
            }
        }')
    
    local response
    response=$(curl -s -X POST \
        "https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent?key=${GEMINI_API_KEY}" \
        -H "Content-Type: application/json" \
        -d "$request_body" 2>&1)
    
    # Check for errors
    if echo "$response" | jq -e '.error' &>/dev/null; then
        local error_msg
        error_msg=$(echo "$response" | jq -r '.error.message // "Unknown error"')
        log_error "Gemini API error: $error_msg"
        return 1
    fi
    
    # Extract the text response
    echo "$response" | jq -r '.candidates[0].content.parts[0].text // ""'
}

generate_ai_pr_description() {
    local ticket="$1"
    local ticket_title="$2"
    local ticket_description="$3"
    local ticket_type="$4"
    local ticket_url="$5"
    local commit_messages="$6"
    local changed_files="$7"
    local diff_content="$8"
    local diff_stat="$9"
    local template_content="${10}"
    
    log_ai "Analyzing code changes with AI..."
    
    # Build the prompt
    local prompt="You are an expert code reviewer helping create a Pull Request description.

## Context

**Jira Ticket:** ${ticket}
**Ticket Title:** ${ticket_title}
**Ticket Type:** ${ticket_type}
**Ticket URL:** ${ticket_url}

**Jira Description/Requirements:**
${ticket_description:-"No description provided"}

**Commits in this PR:**
${commit_messages:-"No commits"}

**Files Changed:**
${changed_files:-"No files"}

**Diff Statistics:**
${diff_stat:-"No stats"}

**Code Diff (truncated if large):**
\`\`\`
${diff_content:-"No diff available"}
\`\`\`

## Your Task

Analyze the code changes and generate a comprehensive PR description. You must:

1. **Summarize what was implemented** - Explain the changes in plain language, relating them to the Jira ticket requirements
2. **Explain the technical approach** - How the changes solve the problem
3. **Identify impacted areas** - What parts of the application are affected
4. **Highlight important changes** - Point out key files/functions reviewers should focus on
5. **Note any potential risks or considerations** - Things reviewers should watch for

## Output Format

Generate the PR description in this exact markdown format:

## Summary
[2-3 sentences summarizing what this PR accomplishes and how it relates to the ticket]

## What Changed
[Bullet points explaining the key changes made]

## Technical Approach
[Brief explanation of how the solution was implemented]

## Impacted Areas
[List the areas/components affected by these changes]

## Key Files to Review
[List the most important files reviewers should focus on, with brief explanation why]

## Testing Considerations
[Suggestions for how to test these changes]

## Jira Ticket
${ticket_url}

---
*This description was generated with AI assistance based on the code diff and Jira ticket.*

IMPORTANT: Be specific and reference actual code, files, and functions from the diff. Don't be generic."

    local ai_response
    ai_response=$(call_gemini_api "$prompt")
    
    if [[ $? -ne 0 ]] || [[ -z "$ai_response" ]]; then
        log_warning "AI generation failed, falling back to basic template"
        generate_basic_description "$ticket_url" "$ticket_description" "$commit_messages" "$changed_files"
        return
    fi
    
    echo "$ai_response"
}

generate_basic_description() {
    local ticket_url="$1"
    local ticket_description="$2"
    local commit_messages="$3"
    local changed_files="$4"
    
    cat << EOF
## Summary
[Please describe your changes]

## What Changed
$(echo "$commit_messages" | while read -r msg; do echo "- $msg"; done)

## Impacted Areas
$(echo "$changed_files" | head -10 | while read -r file; do echo "- \`$file\`"; done)

## Jira Ticket
$ticket_url
EOF
}

#######################################
# PR Template Functions
#######################################

find_pr_template() {
    local repo_root
    repo_root=$(git rev-parse --show-toplevel 2>/dev/null)
    
    if [[ -z "$repo_root" ]]; then
        return 1
    fi
    
    local template_paths=(
        ".github/PULL_REQUEST_TEMPLATE.md"
        ".github/pull_request_template.md"
        ".github/PULL_REQUEST_TEMPLATE/pull_request_template.md"
        "docs/PULL_REQUEST_TEMPLATE.md"
        "PULL_REQUEST_TEMPLATE.md"
    )
    
    for path in "${template_paths[@]}"; do
        local full_path="${repo_root}/${path}"
        if [[ -f "$full_path" ]]; then
            echo "$full_path"
            return 0
        fi
    done
    
    echo ""
}

merge_with_template() {
    local ai_content="$1"
    local template_path="$2"
    local ticket_url="$3"
    
    if [[ -z "$template_path" ]] || [[ ! -f "$template_path" ]]; then
        # No template, use AI content directly
        echo "$ai_content"
        return
    fi
    
    log_info "Merging AI analysis with PR template..."
    
    local template
    template=$(cat "$template_path")
    
    # Replace placeholder Jira URLs
    template=$(echo "$template" | sed -E "s|https://[a-zA-Z0-9.-]+\.atlassian\.net/browse/[A-Z]+-[0-9]+|$ticket_url|g")
    
    # Build merged content: AI content first, then remaining template sections
    local merged=""
    
    # Add the AI-generated content
    merged="$ai_content"
    
    # Add remaining template sections that aren't covered by AI
    # (like Checklist, Screenshots, etc.)
    local in_section=false
    local current_section=""
    local skip_sections="Summary|What Changed|Technical Approach|Impacted Areas|Key Files|Testing|Jira Ticket|Description|Added in this PR"
    
    while IFS= read -r line || [[ -n "$line" ]]; do
        if [[ "$line" =~ ^##\  ]]; then
            current_section="$line"
            # Check if this section is already in AI content
            if echo "$current_section" | grep -qiE "$skip_sections"; then
                in_section=true
            else
                in_section=false
                merged+=$'\n'"$line"
            fi
        elif [[ "$in_section" == false ]]; then
            merged+=$'\n'"$line"
        fi
    done <<< "$template"
    
    echo "$merged"
}

#######################################
# Create Pull Request
#######################################

create_pr() {
    local title="$1"
    local body="$2"
    local base_branch="$3"
    local draft="$4"
    
    log_info "Creating pull request..."
    
    local pr_url
    if [[ "$draft" == "true" ]]; then
        pr_url=$(gh pr create --title "$title" --body "$body" --base "$base_branch" --draft 2>&1)
    else
        pr_url=$(gh pr create --title "$title" --body "$body" --base "$base_branch" 2>&1)
    fi
    
    if [[ $? -eq 0 ]]; then
        log_success "Pull request created successfully!"
        echo -e "${GREEN}PR URL:${NC} $pr_url"
    else
        log_error "Failed to create pull request: $pr_url"
        exit 1
    fi
}

#######################################
# Main Function
#######################################

main() {
    local draft="false"
    local base_branch="main"
    local dry_run="false"
    
    while [[ $# -gt 0 ]]; do
        case $1 in
            --setup)
                setup_api_key
                exit 0
                ;;
            --setup-help)
                show_setup_help
                exit 0
                ;;
            --draft|-d)
                draft="true"
                shift
                ;;
            --base|-b)
                base_branch="$2"
                shift 2
                ;;
            --dry-run)
                dry_run="true"
                shift
                ;;
            --help|-h)
                echo "Usage: auto-pr [OPTIONS]"
                echo ""
                echo "AI-powered PR creation with Jira integration"
                echo ""
                echo "Options:"
                echo "  --setup       Configure Gemini API key"
                echo "  --setup-help  Show full setup instructions"
                echo "  --draft, -d   Create PR as draft"
                echo "  --base, -b    Specify base branch (default: main)"
                echo "  --dry-run     Preview PR without creating"
                echo "  --help, -h    Show this help"
                exit 0
                ;;
            *)
                log_error "Unknown option: $1"
                exit 1
                ;;
        esac
    done
    
    check_prerequisites
    
    local current_branch
    current_branch=$(git branch --show-current)
    
    if [[ -z "$current_branch" ]]; then
        die "Could not determine current branch"
    fi
    
    log_info "Current branch: $current_branch"
    
    # Extract Jira ticket
    local ticket
    ticket=$(extract_jira_ticket "$current_branch")
    
    if [[ -z "$ticket" ]]; then
        die "Could not extract Jira ticket from branch: $current_branch
Expected format: task/PROJ-123 or feature/PROJ-123-description"
    fi
    
    log_success "Found Jira ticket: $ticket"
    
    # Fetch Jira data
    local jira_json
    jira_json=$(fetch_jira_ticket_json "$ticket")
    
    if [[ $? -ne 0 ]] || [[ -z "$jira_json" ]]; then
        die "Failed to fetch Jira ticket details"
    fi
    
    local ticket_title ticket_description ticket_type ticket_url
    ticket_title=$(get_ticket_title "$jira_json")
    ticket_description=$(get_ticket_description "$jira_json")
    ticket_type=$(get_ticket_type "$jira_json")
    ticket_url=$(get_ticket_url "$ticket")
    
    log_success "Ticket: $ticket_title"
    log_info "Type: $ticket_type"
    
    # Get git information
    local resolved_base
    resolved_base=$(get_base_branch "$base_branch")
    
    log_info "Analyzing git changes against ${resolved_base:-HEAD}..."
    
    local commit_messages changed_files diff_content diff_stat
    commit_messages=$(get_commit_messages "$resolved_base")
    changed_files=$(get_changed_files "$resolved_base")
    diff_content=$(get_diff_content "$resolved_base" 800)
    diff_stat=$(get_diff_stat "$resolved_base")
    
    local commit_count file_count
    [[ -n "$commit_messages" ]] && commit_count=$(echo "$commit_messages" | wc -l | tr -d ' ') || commit_count=0
    [[ -n "$changed_files" ]] && file_count=$(echo "$changed_files" | wc -l | tr -d ' ') || file_count=0
    
    log_info "Found $commit_count commit(s) and $file_count changed file(s)"
    
    # Find PR template
    local template_path
    template_path=$(find_pr_template)
    
    if [[ -n "$template_path" ]]; then
        log_info "Found PR template: $template_path"
    fi
    
    # Generate AI-powered description
    local ai_description
    ai_description=$(generate_ai_pr_description \
        "$ticket" \
        "$ticket_title" \
        "$ticket_description" \
        "$ticket_type" \
        "$ticket_url" \
        "$commit_messages" \
        "$changed_files" \
        "$diff_content" \
        "$diff_stat" \
        "")
    
    # Merge with template if exists
    local pr_body
    pr_body=$(merge_with_template "$ai_description" "$template_path" "$ticket_url")
    
    local pr_title="[${ticket}] - ${ticket_title}"
    
    echo ""
    echo "=================================="
    echo -e "${GREEN}PR Title:${NC} $pr_title"
    echo "=================================="
    echo -e "${GREEN}PR Body:${NC}"
    echo "----------------------------------"
    echo "$pr_body"
    echo "----------------------------------"
    echo ""
    
    if [[ "$dry_run" == "true" ]]; then
        log_info "Dry run mode - PR not created"
        exit 0
    fi
    
    read -p "Create this PR? (y/n): " confirm
    if [[ "$confirm" != "y" && "$confirm" != "Y" ]]; then
        log_info "PR creation cancelled"
        exit 0
    fi
    
    create_pr "$pr_title" "$pr_body" "$base_branch" "$draft"
}

main "$@"

# Helper function to validate input
validate_ticket_format() {
    local input="$1"
    if [[ ! "$input" =~ ^[A-Z]+-[0-9]+$ ]]; then
        return 1
    fi
    return 0
}

