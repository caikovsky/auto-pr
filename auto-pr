#!/bin/bash

# auto-pr: Automatically create GitHub PRs with AI-powered descriptions
# Uses Gemini AI to analyze code changes and Jira ticket to generate insightful PR content

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

# Configuration
CONFIG_DIR="${HOME}/.config/auto-pr"
CONFIG_FILE="${CONFIG_DIR}/config"

#######################################
# Utility Functions
#######################################

log_info() {
    echo -e "${BLUE}ℹ${NC} $1" >&2
}

log_success() {
    echo -e "${GREEN}✓${NC} $1" >&2
}

log_warning() {
    echo -e "${YELLOW}⚠${NC} $1" >&2
}

log_error() {
    echo -e "${RED}✗${NC} $1" >&2
}

log_ai() {
    echo -e "${CYAN}🤖${NC} $1" >&2
}

die() {
    log_error "$1"
    exit 1
}

#######################################
# Configuration Management
#######################################

load_config() {
    if [[ -f "$CONFIG_FILE" ]]; then
        source "$CONFIG_FILE"
    fi
}

save_config() {
    mkdir -p "$CONFIG_DIR"
    cat > "$CONFIG_FILE" << EOF
# Auto-PR Configuration
GEMINI_API_KEY="$GEMINI_API_KEY"
EOF
    chmod 600 "$CONFIG_FILE"
}

setup_api_key() {
    echo "Auto-PR Setup"
    echo "============="
    echo ""
    echo "This tool uses Google Gemini AI to analyze your code changes."
    echo ""
    echo "Get your free API key from:"
    echo "  https://aistudio.google.com/app/apikey"
    echo ""
    read -p "Enter your Gemini API key: " api_key
    
    if [[ -z "$api_key" ]]; then
        die "API key is required"
    fi
    
    GEMINI_API_KEY="$api_key"
    save_config
    log_success "Configuration saved to $CONFIG_FILE"
}

#######################################
# Check Prerequisites
#######################################

check_prerequisites() {
    local missing=()
    
    if ! command -v gh &> /dev/null; then
        missing+=("gh (GitHub CLI) - brew install gh")
    fi
    
    if ! command -v acli &> /dev/null; then
        missing+=("acli (Atlassian CLI) - brew install atlassian-labs/tap/acli")
    fi
    
    if ! command -v jq &> /dev/null; then
        missing+=("jq - brew install jq")
    fi
    
    if ! command -v curl &> /dev/null; then
        missing+=("curl")
    fi
    
    if [[ ${#missing[@]} -gt 0 ]]; then
        log_error "Missing required tools:"
        for tool in "${missing[@]}"; do
            echo "  - $tool"
        done
        exit 1
    fi
    
    if ! gh auth status &> /dev/null; then
        die "GitHub CLI is not authenticated. Run: gh auth login"
    fi
    
    if ! acli auth status &> /dev/null 2>&1; then
        log_error "Atlassian CLI is not authenticated."
        log_info "Run: acli auth login"
        exit 1
    fi
    
    # Check for API key
    load_config
    if [[ -z "$GEMINI_API_KEY" ]]; then
        log_warning "Gemini API key not configured."
        setup_api_key
    fi
}

#######################################
# Setup Help
#######################################

show_setup_help() {
