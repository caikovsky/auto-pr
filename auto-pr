#!/bin/bash

# auto-pr: Automatically create GitHub PRs with Atlassian CLI (acli) integration
# Reads PR template, extracts Jira ticket from branch, fills template automatically

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

#######################################
# Utility Functions
#######################################

log_info() {
    echo -e "${BLUE}ℹ${NC} $1" >&2
}

log_success() {
    echo -e "${GREEN}✓${NC} $1" >&2
}

log_warning() {
    echo -e "${YELLOW}⚠${NC} $1" >&2
}

log_error() {
    echo -e "${RED}✗${NC} $1" >&2
}

die() {
    log_error "$1"
    exit 1
}

#######################################
# Check Prerequisites
#######################################

check_prerequisites() {
    local missing=()
    
    if ! command -v gh &> /dev/null; then
        missing+=("gh (GitHub CLI) - install with: brew install gh")
    fi
    
    if ! command -v acli &> /dev/null; then
        missing+=("acli (Atlassian CLI) - install with: brew install atlassian-labs/tap/acli")
    fi
    
    if ! command -v jq &> /dev/null; then
        missing+=("jq - install with: brew install jq")
    fi
    
    if [[ ${#missing[@]} -gt 0 ]]; then
        log_error "Missing required tools:"
        for tool in "${missing[@]}"; do
            echo "  - $tool"
        done
        exit 1
    fi
    
    # Check if gh is authenticated
    if ! gh auth status &> /dev/null; then
        die "GitHub CLI is not authenticated. Run: gh auth login"
    fi
    
    # Check if acli is authenticated
    if ! acli auth status &> /dev/null 2>&1; then
        log_error "Atlassian CLI is not authenticated."
        log_info "Run: acli auth login"
        log_info "See setup instructions with: auto-pr --setup-help"
        exit 1
    fi
}

