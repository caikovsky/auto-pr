#!/bin/bash

# auto-pr: AI-powered PR creation with Jira integration
# Uses gemini, copilot, or agent CLI to analyze code and generate PR descriptions

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

# Configuration
CONFIG_DIR="${HOME}/.config/auto-pr"
CONFIG_FILE="${CONFIG_DIR}/config"

# Supported AI CLIs (gemini, copilot, agent)
AI_CLI="${AI_CLI:-auto}"

# AI CLIs to use in test mode
TEST_AI_CLIS=("gemini" "copilot" "agent")

#######################################
# Utility Functions
#######################################

log_info() {
    echo -e "${BLUE}ℹ${NC} $1" >&2
}

log_success() {
    echo -e "${GREEN}✓${NC} $1" >&2
}

log_warning() {
    echo -e "${YELLOW}⚠${NC} $1" >&2
}

log_error() {
    echo -e "${RED}✗${NC} $1" >&2
}

log_ai() {
    echo -e "${CYAN}🤖${NC} $1" >&2
}

die() {
    log_error "$1"
    exit 1
}

#######################################
# Configuration Management
#######################################

load_config() {
    if [[ -f "$CONFIG_FILE" ]]; then
        source "$CONFIG_FILE"
    fi
}

save_config() {
    mkdir -p "$CONFIG_DIR"
    cat > "$CONFIG_FILE" << EOF
# Auto-PR Configuration
# AI CLI: gemini, copilot, or agent
AI_CLI="${AI_CLI:-auto}"
EOF
    chmod 600 "$CONFIG_FILE"
}

detect_ai_cli() {
    if [[ "$AI_CLI" != "auto" ]] && command -v "$AI_CLI" &>/dev/null; then
        echo "$AI_CLI"
        return 0
    fi
    
    # Auto-detect available CLI (in order of preference)
    if command -v gemini &>/dev/null; then
        echo "gemini"
    elif command -v copilot &>/dev/null; then
        echo "copilot"
    elif command -v agent &>/dev/null; then
        echo "agent"
    else
        echo ""
    fi
}

setup_ai_cli() {
    echo "Auto-PR Setup"
    echo "============="
    echo ""
    echo "Detected AI CLI tools:"
    
    local found=false
    command -v gemini &>/dev/null && echo "  ✓ gemini (Google Gemini CLI)" && found=true
    command -v copilot &>/dev/null && echo "  ✓ copilot (GitHub Copilot CLI)" && found=true
    command -v agent &>/dev/null && echo "  ✓ agent (Cursor Agent CLI)" && found=true
    
    if [[ "$found" == false ]]; then
        echo "  ✗ No AI CLI tools found"
        echo ""
        echo "Install one of:"
        echo "  brew install gemini-cli    # Google Gemini"
        echo "  # GitHub Copilot CLI"
        echo "  # Cursor Agent (comes with Cursor)"
        exit 1
    fi
    
    echo ""
    local detected
    detected=$(detect_ai_cli)
    echo "Auto-detected: $detected"
    echo ""
    read -p "Use '$detected'? (y/n or enter different CLI name): " choice
    
    if [[ "$choice" == "y" || "$choice" == "Y" || -z "$choice" ]]; then
        AI_CLI="$detected"
    else
        AI_CLI="$choice"
    fi
    
    save_config
    log_success "Configuration saved. Using: $AI_CLI"
}

#######################################
# Check Prerequisites
#######################################

check_prerequisites() {
    local missing=()
    
    if ! command -v gh &> /dev/null; then
        missing+=("gh (GitHub CLI) - brew install gh")
    fi
    
    if ! command -v acli &> /dev/null; then
        missing+=("acli (Atlassian CLI) - brew install atlassian-labs/tap/acli")
    fi
    
    if ! command -v jq &> /dev/null; then
        missing+=("jq - brew install jq")
    fi
    
    if [[ ${#missing[@]} -gt 0 ]]; then
        log_error "Missing required tools:"
        for tool in "${missing[@]}"; do
            echo "  - $tool"
        done
        exit 1
    fi
    
    if ! gh auth status &> /dev/null; then
        die "GitHub CLI is not authenticated. Run: gh auth login"
    fi
    
    if ! acli auth status &> /dev/null 2>&1; then
        log_error "Atlassian CLI is not authenticated."
        log_info "Run: acli auth login"
        exit 1
    fi
    
    # Check for AI CLI
    load_config
    DETECTED_AI_CLI=$(detect_ai_cli)
    
    if [[ -z "$DETECTED_AI_CLI" ]]; then
        log_error "No AI CLI tool found."
        log_info "Install one of: gemini, copilot, or agent"
        exit 1
    fi
    
    log_info "Using AI CLI: $DETECTED_AI_CLI"
}

#######################################
# Jira Functions
#######################################

extract_jira_ticket() {
    local branch_name="$1"
    echo "$branch_name" | grep -oE '[A-Z]+-[0-9]+' | head -1
}

fetch_jira_ticket_json() {
    local ticket="$1"
    log_info "Fetching Jira ticket: $ticket"
    
    local response
    response=$(acli jira workitem view "$ticket" --json 2>&1)
    
    if [[ $? -ne 0 ]] || echo "$response" | grep -qi '"error"\|not found'; then
        log_error "Failed to fetch Jira ticket: $ticket"
        return 1
    fi
    
    echo "$response"
}

get_ticket_title() {
    echo "$1" | jq -r '.fields.summary // "No title"'
}

get_ticket_description() {
    echo "$1" | jq -r '
        def extract_text:
            if type == "object" then
                if .text then .text
                elif .content then (.content | map(extract_text) | join(" "))
                else ""
                end
            elif type == "array" then
                map(extract_text) | join(" ")
            else ""
            end;
        .fields.description | extract_text
    ' 2>/dev/null | tr '\n' ' ' | sed 's/  */ /g'
}

get_ticket_type() {
    echo "$1" | jq -r '.fields.issuetype.name // "Task"'
}

get_ticket_url() {
    local ticket="$1"
    local site
    site=$(acli auth status 2>/dev/null | grep -oE '[a-zA-Z0-9.-]+\.atlassian\.net' | head -1)
    
    if [[ -n "$site" ]]; then
        echo "https://${site}/browse/${ticket}"
    else
        echo "https://YOURSITE.atlassian.net/browse/${ticket}"
    fi
}

#######################################
# Git Functions
#######################################

get_base_branch() {
    local base="$1"
    
    if git rev-parse --verify "$base" &>/dev/null; then
        echo "$base"
    elif git rev-parse --verify "origin/$base" &>/dev/null; then
        echo "origin/$base"
    elif git rev-parse --verify "origin/main" &>/dev/null; then
        echo "origin/main"
    elif git rev-parse --verify "origin/master" &>/dev/null; then
        echo "origin/master"
    else
        echo ""
    fi
}

get_commit_messages() {
    local base_branch="$1"
    
    if [[ -z "$base_branch" ]]; then
        git log --oneline -20 --pretty=format:"%s" 2>/dev/null
    else
        git log "${base_branch}..HEAD" --oneline --pretty=format:"%s" 2>/dev/null
    fi
}

get_changed_files() {
    local base_branch="$1"
    
    if [[ -z "$base_branch" ]]; then
        git diff --name-only HEAD~1 2>/dev/null || git ls-files 2>/dev/null
    else
        git diff --name-only "${base_branch}..HEAD" 2>/dev/null
    fi
}

get_diff_content() {
    local base_branch="$1"
    local max_lines="${2:-500}"
    
    local diff
    if [[ -z "$base_branch" ]]; then
        diff=$(git diff HEAD~1 2>/dev/null)
    else
        diff=$(git diff "${base_branch}..HEAD" 2>/dev/null)
    fi
    
    echo "$diff" | head -n "$max_lines"
}

get_diff_stat() {
    local base_branch="$1"
    
    if [[ -z "$base_branch" ]]; then
        git diff --stat HEAD~1 2>/dev/null
    else
        git diff --stat "${base_branch}..HEAD" 2>/dev/null
    fi
}

#######################################
# AI CLI Functions
#######################################

call_ai_cli() {
    local prompt="$1"
    local cli_tool="$2"
    
    local response=""
    
    case "$cli_tool" in
        gemini)
            response=$(echo "$prompt" | gemini -o text 2>/dev/null)
            ;;
        copilot)
            response=$(copilot -p "$prompt" --allow-all-tools 2>/dev/null)
            ;;
        agent)
            response=$(agent -p "$prompt" --output-format text 2>/dev/null)
            ;;
        *)
            log_error "Unknown AI CLI: $cli_tool"
            return 1
            ;;
    esac
    
    if [[ -z "$response" ]]; then
        return 1
    fi
    
    echo "$response"
}

#######################################
# Test Mode: Compare AI Outputs
#######################################

get_available_test_clis() {
    local available=()
    for cli in "${TEST_AI_CLIS[@]}"; do
        if command -v "$cli" &>/dev/null; then
            available+=("$cli")
        fi
    done
    echo "${available[@]}"
}

run_ai_comparison_test() {
    local prompt="$1"
    local output_dir="$2"
    local ticket="$3"
    
    mkdir -p "$output_dir"
    
    local available_clis
    available_clis=($(get_available_test_clis))
    
    if [[ ${#available_clis[@]} -eq 0 ]]; then
        log_error "No AI CLI tools available for testing"
        return 1
    fi
    
    log_info "Running comparison test with ${#available_clis[@]} AI CLI(s): ${available_clis[*]}"
    echo ""
    
    # Save the prompt
    echo "$prompt" > "${output_dir}/prompt.txt"
    log_success "Saved prompt to: ${output_dir}/prompt.txt"
    
    local results_summary=""
    
    for cli in "${available_clis[@]}"; do
        local output_file="${output_dir}/${cli}_output.txt"
        local start_time=$(date +%s)
        
        log_ai "Running $cli..."
        
        local response
        response=$(call_ai_cli "$prompt" "$cli")
        local exit_code=$?
        
        local end_time=$(date +%s)
        local duration=$((end_time - start_time))
        
        if [[ $exit_code -eq 0 ]] && [[ -n "$response" ]]; then
            echo "$response" > "$output_file"
            local word_count=$(echo "$response" | wc -w | tr -d ' ')
            local line_count=$(echo "$response" | wc -l | tr -d ' ')
            
            log_success "$cli: Completed in ${duration}s (${word_count} words, ${line_count} lines)"
            log_info "  Output: $output_file"
            
            results_summary+="## $cli\n"
            results_summary+="- Status: Success\n"
            results_summary+="- Duration: ${duration}s\n"
            results_summary+="- Words: ${word_count}\n"
            results_summary+="- Lines: ${line_count}\n"
            results_summary+="- File: ${cli}_output.txt\n\n"
        else
            echo "ERROR: Failed to generate output" > "$output_file"
            log_error "$cli: Failed after ${duration}s"
            
            results_summary+="## $cli\n"
            results_summary+="- Status: Failed\n"
            results_summary+="- Duration: ${duration}s\n\n"
        fi
        
        echo ""
    done
    
    # Save summary
    local summary_file="${output_dir}/summary.md"
    cat > "$summary_file" << EOF
# AI Comparison Test Results

**Ticket:** ${ticket}
**Date:** $(date '+%Y-%m-%d %H:%M:%S')
**Output Directory:** ${output_dir}

## Results

$(echo -e "$results_summary")

## Files

- \`prompt.txt\` - The prompt sent to all AI CLIs
$(for cli in "${available_clis[@]}"; do echo "- \`${cli}_output.txt\` - Output from $cli"; done)
- \`summary.md\` - This summary file

## Compare Outputs

\`\`\`bash
# Side by side diff
diff -y ${output_dir}/gemini_output.txt ${output_dir}/copilot_output.txt

# Visual diff in Cursor
cursor --diff ${output_dir}/gemini_output.txt ${output_dir}/copilot_output.txt
\`\`\`
EOF

    log_success "Saved summary to: $summary_file"
    echo ""
    echo "============================================"
    echo -e "${GREEN}Test Complete!${NC}"
    echo "============================================"
    echo "Output directory: $output_dir"
    echo ""
    echo "Files:"
    ls -la "$output_dir"
    echo ""
    echo "Compare:"
    echo "  diff -y ${output_dir}/gemini_output.txt ${output_dir}/copilot_output.txt"
}

#######################################
# Generate AI PR Description
#######################################

generate_ai_pr_description() {
    local prompt="$1"
    local ai_cli="$2"
    
    log_ai "Analyzing code changes with $ai_cli..."
    
    local ai_response
    ai_response=$(call_ai_cli "$prompt" "$ai_cli")
    
    if [[ $? -ne 0 ]] || [[ -z "$ai_response" ]]; then
        log_warning "AI generation failed"
        return 1
    fi
    
    echo "$ai_response"
}

#######################################
# PR Template Functions
#######################################

find_pr_template() {
    local repo_root
    repo_root=$(git rev-parse --show-toplevel 2>/dev/null)
    
    if [[ -z "$repo_root" ]]; then
        return 1
    fi
    
    local template_paths=(
        ".github/PULL_REQUEST_TEMPLATE.md"
        ".github/pull_request_template.md"
        ".github/PULL_REQUEST_TEMPLATE/pull_request_template.md"
        "docs/PULL_REQUEST_TEMPLATE.md"
        "PULL_REQUEST_TEMPLATE.md"
    )
    
    for path in "${template_paths[@]}"; do
        local full_path="${repo_root}/${path}"
        if [[ -f "$full_path" ]]; then
            echo "$full_path"
            return 0
        fi
    done
    
    echo ""
}

#######################################
# Create Pull Request
#######################################

create_pr() {
    local title="$1"
    local body="$2"
    local base_branch="$3"
    local draft="$4"
    
    log_info "Creating pull request..."
    
    local pr_url
    if [[ "$draft" == "true" ]]; then
        pr_url=$(gh pr create --title "$title" --body "$body" --base "$base_branch" --draft 2>&1)
    else
        pr_url=$(gh pr create --title "$title" --body "$body" --base "$base_branch" 2>&1)
    fi
    
    if [[ $? -eq 0 ]]; then
        log_success "Pull request created successfully!"
        echo -e "${GREEN}PR URL:${NC} $pr_url"
    else
        log_error "Failed to create pull request: $pr_url"
        exit 1
    fi
}

#######################################
# Main Function
#######################################

main() {
    local draft="false"
    local base_branch="main"
    local dry_run="false"
    local test_mode="false"
    local test_output_dir=""
    local force_ai_cli=""
    
    while [[ $# -gt 0 ]]; do
        case $1 in
            --setup)
                setup_ai_cli
                exit 0
                ;;
            --draft|-d)
                draft="true"
                shift
                ;;
            --base|-b)
                base_branch="$2"
                shift 2
                ;;
            --dry-run)
                dry_run="true"
                shift
                ;;
            --test)
                test_mode="true"
                shift
                if [[ -n "$1" ]] && [[ ! "$1" =~ ^-- ]]; then
                    test_output_dir="$1"
                    shift
                fi
                ;;
            --gemini)
                force_ai_cli="gemini"
                shift
                ;;
            --copilot)
                force_ai_cli="copilot"
                shift
                ;;
            --agent)
                force_ai_cli="agent"
                shift
                ;;
            --help|-h)
                echo "Usage: auto-pr [OPTIONS]"
                echo ""
                echo "AI-powered PR creation with Jira integration"
                echo ""
                echo "Options:"
                echo "  --gemini      Use Google Gemini CLI"
                echo "  --copilot     Use GitHub Copilot CLI"
                echo "  --agent       Use Cursor Agent CLI"
                echo "  --draft, -d   Create PR as draft"
                echo "  --base, -b    Specify base branch (default: main)"
                echo "  --dry-run     Preview PR without creating"
                echo "  --test [dir]  Compare outputs from all AI CLIs"
                echo "  --setup       Configure default AI CLI"
                echo "  --help, -h    Show this help"
                exit 0
                ;;
            *)
                log_error "Unknown option: $1"
                exit 1
                ;;
        esac
    done
    
    check_prerequisites
    
    # Override AI CLI if specified via flag
    if [[ -n "$force_ai_cli" ]]; then
        if ! command -v "$force_ai_cli" &>/dev/null; then
            die "$force_ai_cli CLI is not installed"
        fi
        DETECTED_AI_CLI="$force_ai_cli"
        log_info "Using AI CLI: $DETECTED_AI_CLI (via --$force_ai_cli flag)"
    fi
    
    local current_branch
    current_branch=$(git branch --show-current)
    
    if [[ -z "$current_branch" ]]; then
        die "Could not determine current branch"
    fi
    
    log_info "Current branch: $current_branch"
    
    # Extract Jira ticket
    local ticket
    ticket=$(extract_jira_ticket "$current_branch")
    
    if [[ -z "$ticket" ]]; then
        die "Could not extract Jira ticket from branch: $current_branch
Expected format: task/PROJ-123 or feature/PROJ-123-description"
    fi
    
    log_success "Found Jira ticket: $ticket"
    
    # Fetch Jira data
    local jira_json
    jira_json=$(fetch_jira_ticket_json "$ticket")
    
    if [[ $? -ne 0 ]] || [[ -z "$jira_json" ]]; then
        die "Failed to fetch Jira ticket details"
    fi
    
    local ticket_title ticket_description ticket_type ticket_url
    ticket_title=$(get_ticket_title "$jira_json")
    ticket_description=$(get_ticket_description "$jira_json")
    ticket_type=$(get_ticket_type "$jira_json")
    ticket_url=$(get_ticket_url "$ticket")
    
    log_success "Ticket: $ticket_title"
    log_info "Type: $ticket_type"
    
    # Get git information
    local resolved_base
    resolved_base=$(get_base_branch "$base_branch")
    
    log_info "Analyzing git changes against ${resolved_base:-HEAD}..."
    
    local commit_messages changed_files diff_content diff_stat
    commit_messages=$(get_commit_messages "$resolved_base")
    changed_files=$(get_changed_files "$resolved_base")
    diff_content=$(get_diff_content "$resolved_base" 800)
    diff_stat=$(get_diff_stat "$resolved_base")
    
    local commit_count file_count
    [[ -n "$commit_messages" ]] && commit_count=$(echo "$commit_messages" | wc -l | tr -d ' ') || commit_count=0
    [[ -n "$changed_files" ]] && file_count=$(echo "$changed_files" | wc -l | tr -d ' ') || file_count=0
    
    log_info "Found $commit_count commit(s) and $file_count changed file(s)"
    
    # Build the prompt
    local prompt="You are an expert code reviewer helping create a Pull Request description.

## Context

**Jira Ticket:** ${ticket}
**Ticket Title:** ${ticket_title}
**Ticket Type:** ${ticket_type}
**Ticket URL:** ${ticket_url}

**Jira Description/Requirements:**
${ticket_description:-"No description provided"}

**Commits in this PR:**
${commit_messages:-"No commits"}

**Files Changed:**
${changed_files:-"No files"}

**Diff Statistics:**
${diff_stat:-"No stats"}

**Code Diff (truncated if large):**
\`\`\`
${diff_content:-"No diff available"}
\`\`\`

## Your Task

Analyze the code changes and generate a comprehensive PR description:

1. **Summarize what was implemented** - Relate changes to the Jira ticket requirements
2. **Explain the technical approach** - How the changes solve the problem
3. **Identify impacted areas** - What parts of the application are affected
4. **Highlight important changes** - Key files/functions reviewers should focus on
5. **Note potential risks** - Things reviewers should watch for

## Output Format

## Summary
[2-3 sentences summarizing what this PR accomplishes]

## What Changed
[Bullet points explaining the key changes]

## Technical Approach
[Brief explanation of the implementation]

## Impacted Areas
[List affected components]

## Key Files to Review
[Important files with brief explanation]

## Testing Considerations
[How to test these changes]

## Jira Ticket
${ticket_url}

IMPORTANT: Be specific and reference actual code, files, and functions from the diff."

    # TEST MODE
    if [[ "$test_mode" == "true" ]]; then
        if [[ -z "$test_output_dir" ]]; then
            test_output_dir="./auto-pr-test-$(date +%Y%m%d-%H%M%S)"
        fi
        run_ai_comparison_test "$prompt" "$test_output_dir" "$ticket"
        exit 0
    fi
    
    # Generate AI description
    local ai_description
    ai_description=$(generate_ai_pr_description "$prompt" "$DETECTED_AI_CLI")
    
    if [[ $? -ne 0 ]] || [[ -z "$ai_description" ]]; then
        die "Failed to generate PR description"
    fi
    
    local pr_body="$ai_description"
    local pr_title="[${ticket}] - ${ticket_title}"
    
    echo ""
    echo "=================================="
    echo -e "${GREEN}PR Title:${NC} $pr_title"
    echo "=================================="
    echo -e "${GREEN}PR Body:${NC}"
    echo "----------------------------------"
    echo "$pr_body"
    echo "----------------------------------"
    echo ""
    
    if [[ "$dry_run" == "true" ]]; then
        log_info "Dry run mode - PR not created"
        exit 0
    fi
    
    read -p "Create this PR? (y/n): " confirm
    if [[ "$confirm" != "y" && "$confirm" != "Y" ]]; then
        log_info "PR creation cancelled"
        exit 0
    fi
    
    create_pr "$pr_title" "$pr_body" "$base_branch" "$draft"
}

main "$@"
