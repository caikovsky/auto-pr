#!/bin/bash

# auto-pr: Automatically create GitHub PRs with Atlassian CLI (acli) integration
# Reads PR template, extracts Jira ticket from branch, fills template automatically

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

#######################################
# Utility Functions
#######################################

log_info() {
    echo -e "${BLUE}ℹ${NC} $1" >&2
}

log_success() {
    echo -e "${GREEN}✓${NC} $1" >&2
}

log_warning() {
    echo -e "${YELLOW}⚠${NC} $1" >&2
}

log_error() {
    echo -e "${RED}✗${NC} $1" >&2
}

die() {
    log_error "$1"
    exit 1
}

#######################################
# Check Prerequisites
#######################################

check_prerequisites() {
    local missing=()
    
    if ! command -v gh &> /dev/null; then
        missing+=("gh (GitHub CLI) - install with: brew install gh")
    fi
    
    if ! command -v acli &> /dev/null; then
        missing+=("acli (Atlassian CLI) - install with: brew install atlassian-labs/tap/acli")
    fi
    
    if ! command -v jq &> /dev/null; then
        missing+=("jq - install with: brew install jq")
    fi
    
    if [[ ${#missing[@]} -gt 0 ]]; then
        log_error "Missing required tools:"
        for tool in "${missing[@]}"; do
            echo "  - $tool"
        done
        exit 1
    fi
    
    # Check if gh is authenticated
    if ! gh auth status &> /dev/null; then
        die "GitHub CLI is not authenticated. Run: gh auth login"
    fi
    
    # Check if acli is authenticated
    if ! acli auth status &> /dev/null 2>&1; then
        log_error "Atlassian CLI is not authenticated."
        log_info "Run: acli auth login"
        exit 1
    fi
}

#######################################
# Setup Help
#######################################

show_setup_help() {
    cat << 'EOF'
Auto-PR Setup Guide
===================

## 1. Install Required Tools

```bash
brew install gh jq
brew install atlassian-labs/tap/acli
```

## 2. Configure GitHub CLI

```bash
gh auth login
```

## 3. Configure Atlassian CLI

```bash
acli auth login
```

## 4. Verify Setup

```bash
acli auth status
acli jira workitem view PROJ-123
gh auth status
```

## 5. Add auto-pr to PATH

Add to ~/.zshrc:
```bash
export PATH="$PATH:/path/to/automate-pr"
```

## Usage

```bash
cd /path/to/your/repo
git checkout task/TLAB-2023
auto-pr --dry-run    # Preview
auto-pr              # Create PR
```

EOF
}

#######################################
# Extract Jira Ticket from Branch Name
#######################################

extract_jira_ticket() {
    local branch_name="$1"
    echo "$branch_name" | grep -oE '[A-Z]+-[0-9]+' | head -1
}

#######################################
# Fetch Jira Ticket Details using ACLI
#######################################

fetch_jira_ticket_json() {
    local ticket="$1"
    
    log_info "Fetching Jira ticket: $ticket"
    
    local response
    response=$(acli jira workitem view "$ticket" --json 2>&1)
    local exit_code=$?
    
    if [[ $exit_code -ne 0 ]] || echo "$response" | grep -qi '"error"\|not found\|does not exist'; then
        log_error "Failed to fetch Jira ticket: $ticket"
        return 1
    fi
    
    echo "$response"
}

#######################################
# Parse Jira Ticket Data
#######################################

get_ticket_title() {
    local json_data="$1"
    echo "$json_data" | jq -r '.fields.summary // "No title"'
}

get_ticket_description() {
    local json_data="$1"
    local desc
    desc=$(echo "$json_data" | jq -r '
        def extract_text:
            if type == "object" then
                if .text then .text
                elif .content then (.content | map(extract_text) | join(" "))
                else ""
                end
            elif type == "array" then
                map(extract_text) | join(" ")
            else ""
            end;
        .fields.description | extract_text
    ' 2>/dev/null | tr '\n' ' ' | sed 's/  */ /g')
    
    if [[ -z "$desc" || "$desc" == "null" || "$desc" == " " ]]; then
        desc=""
    fi
    
    echo "$desc"
}

get_ticket_type() {
    local json_data="$1"
    echo "$json_data" | jq -r '.fields.issuetype.name // "Task"'
}

get_ticket_status() {
    local json_data="$1"
    echo "$json_data" | jq -r '.fields.status.name // "Unknown"'
}

get_ticket_url() {
    local ticket="$1"
    
    local site
    site=$(acli auth status 2>/dev/null | grep -oE '[a-zA-Z0-9.-]+\.atlassian\.net' | head -1)
    
    if [[ -n "$site" ]]; then
        echo "https://${site}/browse/${ticket}"
    else
        echo "https://YOURSITE.atlassian.net/browse/${ticket}"
    fi
}

#######################################
# Git Information Functions
#######################################

get_base_branch() {
    local base="$1"
    
    if git rev-parse --verify "$base" &>/dev/null; then
        echo "$base"
    elif git rev-parse --verify "origin/$base" &>/dev/null; then
        echo "origin/$base"
    elif git rev-parse --verify "origin/main" &>/dev/null; then
        echo "origin/main"
    elif git rev-parse --verify "origin/master" &>/dev/null; then
        echo "origin/master"
    else
        echo ""
    fi
}

get_commit_messages() {
    local base_branch="$1"
    
    if [[ -z "$base_branch" ]]; then
        git log --oneline -10 --pretty=format:"- %s" 2>/dev/null
    else
        git log "${base_branch}..HEAD" --oneline --pretty=format:"- %s" 2>/dev/null
    fi
}

get_changed_files() {
    local base_branch="$1"
    
    if [[ -z "$base_branch" ]]; then
        git diff --name-only HEAD~1 2>/dev/null || git ls-files 2>/dev/null
    else
        git diff --name-only "${base_branch}..HEAD" 2>/dev/null
    fi
}

get_diff_stat() {
    local base_branch="$1"
    
    if [[ -z "$base_branch" ]]; then
        git diff --stat HEAD~1 2>/dev/null
    else
        git diff --stat "${base_branch}..HEAD" 2>/dev/null
    fi
}

get_impacted_areas() {
    local changed_files="$1"
    
    if [[ -z "$changed_files" ]]; then
        echo "- No files changed"
        return
    fi
    
    echo "$changed_files" | while read -r file; do
        if [[ -n "$file" ]]; then
            local dir=$(dirname "$file" | cut -d'/' -f1-2)
            if [[ "$dir" == "." ]]; then
                echo "Root"
            else
                echo "$dir"
            fi
        fi
    done | sort -u | head -10 | while read -r area; do
        echo "- \`$area\`"
    done
}

#######################################
# Find PR Template
#######################################

find_pr_template() {
    local repo_root
    repo_root=$(git rev-parse --show-toplevel 2>/dev/null)
    
    if [[ -z "$repo_root" ]]; then
        return 1
    fi
    
    local template_paths=(
        ".github/PULL_REQUEST_TEMPLATE.md"
        ".github/pull_request_template.md"
        ".github/PULL_REQUEST_TEMPLATE/pull_request_template.md"
        "docs/PULL_REQUEST_TEMPLATE.md"
        "PULL_REQUEST_TEMPLATE.md"
    )
    
    for path in "${template_paths[@]}"; do
        local full_path="${repo_root}/${path}"
        if [[ -f "$full_path" ]]; then
            echo "$full_path"
            return 0
        fi
    done
    
    log_warning "No PR template found, using default template"
    echo ""
}

#######################################
# Generate PR Description
#######################################

generate_pr_description() {
    local template_path="$1"
    local ticket="$2"
    local ticket_url="$3"
    local ticket_description="$4"
    local ticket_type="$5"
    local commit_messages="$6"
    local changed_files="$7"
    local diff_stat="$8"
    
    # Read template or use default
    local template=""
    if [[ -n "$template_path" && -f "$template_path" ]]; then
        template=$(cat "$template_path")
    else
        template="## Description

<!-- Description will be filled automatically -->

## Jira Ticket

<!-- Jira link -->

## Impacted Areas

<!-- Areas affected -->

## Checklist
- [ ] Self-review completed
- [ ] Tests added/updated"
    fi
    
    # Build description content
    local description_parts=""
    
    if [[ -n "$ticket_description" ]]; then
        description_parts="**Jira Description:** $ticket_description"
    fi
    
    if [[ -n "$commit_messages" ]]; then
        if [[ -n "$description_parts" ]]; then
            description_parts="$description_parts

**Commits:**
$commit_messages"
        else
            description_parts="**Commits:**
$commit_messages"
        fi
    fi
    
    # Build impacted areas
    local impacted_areas=""
    if [[ -n "$changed_files" ]]; then
        impacted_areas=$(get_impacted_areas "$changed_files")
    fi
    
    # Process template line by line
    local output=""
    local in_section=""
    local section_filled=false
    local prev_was_header=false
    
    while IFS= read -r line || [[ -n "$line" ]]; do
        # Check if this is a section header
        if [[ "$line" =~ ^##\  ]]; then
            in_section="$line"
            section_filled=false
            prev_was_header=true
            output+="$line"$'\n'
            continue
        fi
        
        # Check if this is an HTML comment (placeholder) or empty line after header
        local is_placeholder=false
        if [[ "$line" =~ ^[[:space:]]*\<!--.*--\>$ ]]; then
            is_placeholder=true
        fi
        
        # Skip placeholder comments if section was already filled
        if [[ "$is_placeholder" == true ]] && [[ "$section_filled" == true ]]; then
            continue
        fi
        
        # Fill section content
        if [[ "$section_filled" == false ]] && { [[ "$is_placeholder" == true ]] || { [[ "$prev_was_header" == true ]] && [[ -z "$line" || "$line" =~ ^[[:space:]]*$ ]]; }; }; then
            prev_was_header=false
            
            case "$in_section" in
                *"JIRA"*|*"Jira Ticket"*)
                    output+="$ticket_url"$'\n'
                    section_filled=true
                    continue
                    ;;
                *"Description"*|*"Added in this PR"*)
                    if [[ -n "$description_parts" ]]; then
                        output+="$description_parts"$'\n'
                        section_filled=true
                        continue
                    fi
                    ;;
                *"Impacted Areas"*)
                    if [[ -n "$impacted_areas" ]]; then
                        output+="$impacted_areas"$'\n'
                        section_filled=true
                        continue
                    fi
                    ;;
                *"Type of Change"*)
                    output+="$ticket_type"$'\n'
                    section_filled=true
                    continue
                    ;;
            esac
        fi
        
        prev_was_header=false
        
        # Check for placeholder Jira URLs and replace them
        if [[ "$line" =~ https://[a-zA-Z0-9.-]+\.atlassian\.net/browse/[A-Z]+-[0-9]+ ]]; then
            line=$(echo "$line" | sed -E "s|https://[a-zA-Z0-9.-]+\.atlassian\.net/browse/[A-Z]+-[0-9]+|$ticket_url|g")
        fi
        
        output+="$line"$'\n'
    done <<< "$template"
    
    # Remove trailing newline
    echo "${output%$'\n'}"
}

#######################################
# Create Pull Request
#######################################

create_pr() {
    local title="$1"
    local body="$2"
    local base_branch="$3"
    local draft="$4"
    
    log_info "Creating pull request..."
    
    local pr_url
    if [[ "$draft" == "true" ]]; then
        pr_url=$(gh pr create --title "$title" --body "$body" --base "$base_branch" --draft 2>&1)
    else
        pr_url=$(gh pr create --title "$title" --body "$body" --base "$base_branch" 2>&1)
    fi
    
    if [[ $? -eq 0 ]]; then
        log_success "Pull request created successfully!"
        echo -e "${GREEN}PR URL:${NC} $pr_url"
    else
        log_error "Failed to create pull request: $pr_url"
        exit 1
    fi
}

#######################################
# Main Function
#######################################

main() {
    local draft="false"
    local base_branch="main"
    local dry_run="false"
    
    while [[ $# -gt 0 ]]; do
        case $1 in
            --setup-help|--setup)
                show_setup_help
                exit 0
                ;;
            --draft|-d)
                draft="true"
                shift
                ;;
            --base|-b)
                base_branch="$2"
                shift 2
                ;;
            --dry-run)
                dry_run="true"
                shift
                ;;
            --help|-h)
                echo "Usage: auto-pr [OPTIONS]"
                echo ""
                echo "Options:"
                echo "  --setup-help  Show setup instructions"
                echo "  --draft, -d   Create PR as draft"
                echo "  --base, -b    Specify base branch (default: main)"
                echo "  --dry-run     Preview PR without creating"
                echo "  --help, -h    Show this help"
                exit 0
                ;;
            *)
                log_error "Unknown option: $1"
                exit 1
                ;;
        esac
    done
    
    check_prerequisites
    
    local current_branch
    current_branch=$(git branch --show-current)
    
    if [[ -z "$current_branch" ]]; then
        die "Could not determine current branch"
    fi
    
    log_info "Current branch: $current_branch"
    
    local ticket
    ticket=$(extract_jira_ticket "$current_branch")
    
    if [[ -z "$ticket" ]]; then
        die "Could not extract Jira ticket from branch: $current_branch
Expected format: task/PROJ-123 or feature/PROJ-123-description"
    fi
    
    log_success "Found Jira ticket: $ticket"
    
    local jira_json
    jira_json=$(fetch_jira_ticket_json "$ticket")
    
    if [[ $? -ne 0 || -z "$jira_json" ]]; then
        die "Failed to fetch Jira ticket details"
    fi
    
    local ticket_title ticket_description ticket_type ticket_status ticket_url
    ticket_title=$(get_ticket_title "$jira_json")
    ticket_description=$(get_ticket_description "$jira_json")
    ticket_type=$(get_ticket_type "$jira_json")
    ticket_status=$(get_ticket_status "$jira_json")
    ticket_url=$(get_ticket_url "$ticket")
    
    log_success "Ticket title: $ticket_title"
    log_info "Ticket type: $ticket_type"
    log_info "Ticket status: $ticket_status"
    
    local resolved_base
    resolved_base=$(get_base_branch "$base_branch")
    
    log_info "Analyzing commits and changes..."
    
    local commit_messages changed_files diff_stat
    commit_messages=$(get_commit_messages "$resolved_base")
    changed_files=$(get_changed_files "$resolved_base")
    diff_stat=$(get_diff_stat "$resolved_base")
    
    local commit_count file_count
    if [[ -n "$commit_messages" ]]; then
        commit_count=$(echo "$commit_messages" | grep -c "^-" 2>/dev/null || echo "0")
    else
        commit_count=0
    fi
    
    if [[ -n "$changed_files" ]]; then
        file_count=$(echo "$changed_files" | wc -l | tr -d ' ')
    else
        file_count=0
    fi
    
    log_info "Found $commit_count commit(s) and $file_count changed file(s)"
    
    local template_path
    template_path=$(find_pr_template)
    
    local pr_body
    pr_body=$(generate_pr_description \
        "$template_path" \
        "$ticket" \
        "$ticket_url" \
        "$ticket_description" \
        "$ticket_type" \
        "$commit_messages" \
        "$changed_files" \
        "$diff_stat")
    
    local pr_title="[${ticket}] - ${ticket_title}"
    
    echo ""
    echo "=================================="
    echo -e "${GREEN}PR Title:${NC} $pr_title"
    echo "=================================="
    echo -e "${GREEN}PR Body:${NC}"
    echo "----------------------------------"
    echo "$pr_body"
    echo "----------------------------------"
    echo ""
    
    if [[ "$dry_run" == "true" ]]; then
        log_info "Dry run mode - PR not created"
        exit 0
    fi
    
    read -p "Create this PR? (y/n): " confirm
    if [[ "$confirm" != "y" && "$confirm" != "Y" ]]; then
        log_info "PR creation cancelled"
        exit 0
    fi
    
    create_pr "$pr_title" "$pr_body" "$base_branch" "$draft"
}

main "$@"
